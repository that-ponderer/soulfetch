# Memory {{{
get_memory_dynamic(){
    local interval=${1}
    local memory_file="/proc/meminfo"

    while IFS=":" read -r key value; do
        case $key in
            "MemTotal") 
                total_memory="${value/kB}" ;;
            "MemAvailable")
                memory_used="$(( total_memory - ${value/kB} ))"
            ;;
        esac
    done < "$memory_file"

    trim "$total_memory"
    total_memory="$trimmed"
    trim "$memory_used"
    memory_used="$trimmed"

    sleep "$interval"
}
memory_daemon(){
    while true ; do
        get_memory_dynamic 1 
        local memory_data="
memory_used,$memory_used
total_memory,$total_memory
" 
# `read` does not read the last line if it does not include a newline
        printf '%s' "$memory_data" > "$memory_cache_file"    
    done
}
