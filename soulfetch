# Fan {{{
get_fan_speed_dynamic(){
    local interval=${1}
    local -A fan_input_files

    for dev in /sys/class/hwmon/* ; do
        for file in "$dev"/* ; do
            if [[ "$file" == */fan*input ]] ; then
                local value="$file"
                local key="${file/*'/'}"
                key="${key/_*}"
                fan_input_files["$key"]="$file"
            fi
        done
    done
    
    [[ -z "${fan_input_files[*]}" ]] && return 1
    for fan in "${!fan_input_files[@]}" ; do 
        fan_speed_arr["$fan"]="$(< "${fan_input_files[$fan]}")"
    done
    sleep "$interval"
}
fan_daemon(){
    while true ; do
        get_fan_speed_dynamic 1
        local fan_data=""
        for key in "${!fan_speed_arr[@]}" ; do
            fan_data+="fan,$key,${fan_speed_arr[$key]}\n"
        done
        printf '%b' "$fan_data" > "$fan_cache_file"    
    done
}
