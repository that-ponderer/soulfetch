# GPU {{{
declare can_get_gpu
declare -a nvidia_gpus
declare -a intel_gpus
declare has_NVIDIA=false
declare has_Intel=false
declare intel_daemon_running=false

init_gpu(){
    if ! [[ -x $(which lspci 2> /dev/null) ]] ; then
        can_get_gpu=false
    else
        can_get_gpu=true
    fi
}
get_gpu() {
    local gpu_command="lspci -mm"
    declare -A gpu_raw
    while IFS='"' read -ra parts ; do
        if [[ "${parts[1]}" == +(VGA*|Display*|3D*) ]] ; then
            trim "${parts[0]}"
            gpu_raw["${trimmed}"]="${parts[3]} ${parts[5]}"
        fi
    done < <( $gpu_command )
    for key in "${!gpu_raw[@]}" ; do
        case "${gpu_raw[$key]}" in
            *"Advanced"*)
                brand="${gpu_raw[$key]/*AMD*ATI*/AMD ATI}"
                brand="${brand:-${gpu_raw[$key]/*AMD*/AMD}}"
                brand="${brand:-${gpu_raw[$key]/*ATI*/ATi}}"

                gpu_raw[$key]="${gpu_raw[$key]/\[AMD\/ATI\] }"
                gpu_raw[$key]="${gpu_raw[$key]/\[AMD\] }"
                gpu_raw[$key]="${gpu_raw[$key]/OEM }"
                gpu_raw[$key]="${gpu_raw[$key]/Advanced Micro Devices, Inc.}"
                gpu_raw[$key]="${gpu_raw[$key]/*\[}"
                gpu_raw[$key]="${gpu_raw[$key]/\]*}"
                gpu_raw[$key]="$brand ${gpu_raw[$key]}"
            ;;

            *"NVIDIA"*)
                gpu_raw[$key]="${gpu_raw[$key]/*\[}"
                gpu_raw[$key]="${gpu_raw[$key]/\]*}"
                gpu_raw[$key]="NVIDIA ${gpu_raw[$key]}"
            ;;

            *"Intel"*)
                gpu_raw[$key]="${gpu_raw[$key]/*Intel/Intel}"
                gpu_raw[$key]="${gpu_raw[$key]/\(R\)}"
                gpu_raw[$key]="${gpu_raw[$key]/Corporation}"
                gpu_raw[$key]="${gpu_raw[$key]/ \(*}"
                gpu_raw[$key]="${gpu_raw[$key]/Integrated Graphics Controller}"
                gpu_raw[$key]="${gpu_raw[$key]/*Xeon*/Intel HD Graphics}"
            ;;

            *"MCST"*)
                gpu_raw[$key]="${gpu_raw[$key]/*MCST*MGA2*/MCST MGA2}"
            ;;

            *"VirtualBox"*)
                gpu_raw[$key]="VirtualBox Graphics Adapter"
            ;;

            *) return ;;
        esac
        normalize_spaces "${gpu_raw[$key]}"
        gpu_arr[$key]="${normalized_str}"
    done
}
init_gpu_dynamic(){
    # Super sketchy need better ways -------------------------
    for bus_id in "${!gpu_arr[@]}" ; do 
        if [[ "${gpu_arr[$bus_id]}" == NVIDIA* ]] ; then 
            nvidia_gpus+=( "$bus_id" )
        elif [[ "${gpu_arr[$bus_id]}" == Intel* ]] ; then 
            intel_gpus+=( "$bus_id" )
        fi
    done
    # --------------------------------------------------------
    if [[ -n "${nvidia_gpus[*]}" ]] ; then
        if ! [[ -x $(which nvidia-smi  2> /dev/null) ]] ; then
            return 1
        else
            has_NVIDIA=true
        fi
    fi
    if [[ -n "${intel_gpus[*]}" ]] ; then
        if ! [[ -x $(which intel_gpu_top  2> /dev/null) ]] ; then
            return 1
        else
            if ! [[ "$(getcap "$(which intel_gpu_top)")" == *cap_perfmon=ep* ]]
            then
                return 1
            else
                has_Intel=true
            fi
        fi
    fi
}
get_gpu_dynamic() {
    local interval="${1}"

    NVIDIA() {
        # pcie_bus_id: It's the location of the device on the PCI/PCIe bus 
        #              hierarchy
        # format:      domain:bus:device.function
        # Domain:      The PCI domain separates completely independent PCI 
        #              hierarchies. Most consumer systems have only one domain
        # Bus:         The CPU/root complex starts with bus 00, then PCI bridges 
        #              create new buses.
        # Device:      Each bus can have 32 devices:
        # Function:    Each device can have up to 8 functions:
        local pcie_bus_id util mem_used total_mem temp
        while IFS=, read -r pcie_bus_id util mem_used total_mem temp ; do 
            # -----------------------------
            pcie_bus_id="${pcie_bus_id#*:}"
            trim "$pcie_bus_id"
            pcie_bus_id="$trimmed"
            # -----------------------------
            trim "$util"
            util="$trimmed"
            gpu_usage_arr["$pcie_bus_id"]="$util"
            # -----------------------------
            trim "$mem_used"
            mem_used="$trimmed"
            vram_usage_arr["$pcie_bus_id"]="$mem_used"
            # -----------------------------
            trim "$total_mem"
            total_mem="$trimmed"
            total_vram_arr["$pcie_bus_id"]="$total_mem"
            # -----------------------------
            trim "$temp"
            temp="$trimmed"
            gpu_temp_arr["$pcie_bus_id"]="$temp"
            # -----------------------------
        done < <(nvidia-smi \
--query-gpu=pci.bus_id,utilization.gpu,memory.used,memory.total,temperature.gpu \
            --format=csv,noheader,nounits)
    }
    
    INTEL(){
        local temp_file="${cache_files}[Intel]"
        if ! $intel_daemon_running ; then
            for pcie_bus_id in "${intel_gpus[@]}"; do
                intel_gpu_top -c -s "$((  interval * 1000 ))" -d  \
                    "sys:/sys/devices/pci0000:00/0000:$pcie_bus_id" \
                    > "$temp_file" &
                daemon_PID_arr+=( $! )
                temp_file_arr+=( "$temp_file" )
            done
        fi
        intel_daemon_running=true
        
        local Freq_req Freq_act IRQ RC6 render_usage
        for pcie_bus_id in "${intel_gpus[@]}" ; do 
            while IFS=, read -r Freq_req Freq_act IRQ RC6 \
                Power_gpu Power_pkg RCS rest ; do
                # Intel GPUs have different hardware engines, 
                # each doing different tasks. 
                # RCS: Usage of the main 3D rendering engine.
                # BCS: Blitter Copy Engine
                # VCS: Video Codec Engine
                # VECS: Video Enhancement Engine
                if [[ "$Freq_req" == "Freq MHz req" ]] ; then continue ; fi
                render_usage="${RCS}"
                gpu_usage_arr["$pcie_bus_id"]="${render_usage/.*}"
            done < <(tail -n 1 "$temp_file")
        done
    }
    
    sleep "$interval"
    $has_NVIDIA && NVIDIA
    $has_Intel && INTEL
}
gpu_daemon(){
    init_gpu
    # keep atleast somthing running so you dont end
    # up killing some poor random unrelated process 
    $can_get_gpu || { while true ; do sleep 1000 ; done ; }
    get_gpu
    init_gpu_dynamic
    while true ; do
        get_gpu_dynamic 1
        local gpu_data=""
        for key in "${!gpu_arr[@]}" ; do
            gpu_data+="gpu,$key,${gpu_arr[$key]}\n"
        done
        for key in "${!gpu_temp_arr[@]}" ; do
            gpu_data+="gpu_temp,$key,${gpu_temp_arr[$key]}\n"
        done
        for key in "${!gpu_usage_arr[@]}" ; do
            gpu_data+="gpu_usage,$key,${gpu_usage_arr[$key]}\n"
        done
        for key in "${!total_vram_arr[@]}" ; do
            gpu_data+="total_vram,$key,${total_vram_arr[$key]}\n"
        done
        for key in "${!vram_usage_arr[@]}" ; do
            gpu_data+="vram_usage,$key,${vram_usage_arr[$key]}\n"
        done
        printf '%b' "$gpu_data" > "$gpu_cache_file"    
    done
}
