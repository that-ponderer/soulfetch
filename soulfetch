# Gen_Info {{{
progess_bar() {
    local current="$1"
    local total="$2"
    local bar_count="${3:-40}"

    local percent="$(( current * 100 / total ))"
    local filled_bars="$(( bar_count * percent / 100 ))" 
    (( filled_bars == 0 )) && filled_bars=1
    local empty_bars="$(( bar_count - filled_bars ))" 

    printf '[ '
    for ((i=0; i < filled_bars; i++)) ; do printf '\e[32mтЦа' ; done
    for ((i=0; i < empty_bars; i++)) ; do printf '\e[33mтФА' ; done
    printf ' \e[0m]'
}
