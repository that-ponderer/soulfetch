# Consts -----------------------------------------------------
readonly PI=31416 # ╧А * 10000
readonly TWO_PI=$(( PI * 2 ))
readonly SIN_RANGE=100  # range of sin(x)=(-SIN_RANGE,+SIN_RANGE)
readonly SIN_DENSITY=100 # more points, more accurate

# Arithmetic -------------------------------------------------
sqrt() {
    # Babylonian method for square root
    # ---------------------------------
    local n=$1
    # we are taking the value itself as the 
    # first estimation which is less then ideal
    local x=$n
    local y=$(( (x + 1) / 2 ))

    while (( y < x )); do
        x=$y
        y=$(( (x + n / x) / 2 ))
    done

    SQRT="$x"
}
# Vec2 -------------------------------------------------------
vec2_pack() {
    # Packs two integers into a vector: (x,y)
    local x="${1:-0}"
    local y="${2:-0}"
    VEC2="($x,$y)"
}
vec2_unpack() {
    # Unpacks into two integers: X Y 
    local vec="${1:-(0,0)}"
    local regex='^\(([0-9]+),([0-9]+)\)$' # does not match wp: (123, 456)
    [[ "$vec" =~ $regex ]]
    local x="${BASH_REMATCH[1]}"
    [[ -z "$x" ]] && x=0
    local y="${BASH_REMATCH[2]}"
    [[ -z "$y" ]] && y=0
    X="$x" 
    Y="$y"
}
vec2_add(){
    # Add 2 vectors
    local vec2_1="$1"
    local vec2_2="$2"
    vec2_unpack "$vec2_1"
    local x1="$X"
    local y1="$Y"
    vec2_unpack "$vec2_2"
    local x2="$X"
    local y2="$Y"

    local x3=$(( x1 + x2 ))
    local y3=$(( y1 + y2 ))
    vec2_pack $x3 $y3
}
vec2_dist(){
    # Calculate the dist between vectors: R
    local vec2_1="$1"
    local vec2_2="$2"
    vec2_unpack "$vec2_1"
    local x1="$X"
    local y1="$Y"
    vec2_unpack "$vec2_2"
    local x2="$X"
    local y2="$Y"
    sqrt "$(( ((x2 - x1) ** 2) + ((y2 - y1) ** 2) ))"
    R="$SQRT"
}
# Trigo ------------------------------------------------------
gen_sin_table() {
    # Map SIN_DENSITY number of values around the circle (TWO_PI:360 deg)
    # Value will be: 0 -> TWO_PI 
    for ((i=0; i<SIN_DENSITY; i++)); do
        # -----------------------------
        # SIN_DENSITY < TWO_PI
        # We can't map a bigger number to a smaller one 
        # without floats
        # -----------------------------
        local x=$(( i * TWO_PI / SIN_DENSITY ))
        local sign=1
        # Make half the values neg
        # -PI -> 0 -> PI
        if (( x > PI )); then
            x=$(( x - PI ))
            sign=-1
        fi
        # ------------------------
        # Now we have SIN_DENSITY number of values in radians
        # That are signed and map around the whole circle
        # ------------------------
        # Bh─Бskara I approximation
        # sin(x) тЙИ 16x(╧А-x) / (5╧А┬▓ - 4x(╧А-x))
        # x:angle in radians

        local num=$(( 16 * x * (PI - x) ))
        local den=$(( 5 * PI * PI - 4 * x * (PI - x) ))
        if (( den == 0 )); then
            local value=0
        else
            # num / dev = (-1,1)
            # so we scale that with SIN_RANGE
            local value=$(( num * SIN_RANGE / den ))
        fi
        SIN_TABLE+=( $(( value * sign )) )
    done
}
gen_sin_table
