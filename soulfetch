# Helpers {{{
bash_sleep() {
    # sleep while boggig the cpu down
    local ms="$1"
    local start="${EPOCHREALTIME/./}"
    while true ; do
        local end="${EPOCHREALTIME/./}"
        local diff=$(( (end - start ) / 1000 )) 
        (( diff > ms )) && break
    done
}
trim() {
    local var="$1"
    trimmed="${var#"${var%%[![:space:]]*}"}"
    trimmed="${trimmed%"${trimmed##*[![:space:]]}"}"
}
normalize_spaces() {
    local str="$*"
    # dont qoute, we need the word splitting
    # bash excludes the spaces and takes only 
    # the words as arguments
    set -- $str
    normalized_str="$*"
}
get_cursor_pos() {
    local response
    # Ask terminal (DSR) for cursor position
    printf '\e[6n'
    # Terminal responds in stdin: ESC[row;colR
    # -s -> silent mode: dont print anything while reading (precaution)
    # -r -> stop mangling backslashes (shellcheck keeps screaming)
    # -dR -> stop reading at R
    read -srdR response
    # response looks like: ESC[12;40
    # Match digits;digits at the end
    local regex='\[([0-9]+);([0-9]+)$'
    if [[ $response =~  $regex ]] ; then
        vec2_pack "${BASH_REMATCH[2]}" "${BASH_REMATCH[1]}"
        CURSOR_POS="$VEC2"
    fi
}
