# CPU {{{
get_cpu() {
    # Get cpu info and count
    local cpu_file="/proc/cpuinfo"
    local break_counter=2
    while IFS= read -r line ; do
        (( break_counter <= 0 )) && break
        if [[ "$line" == 'model name'* ]] ; then
            local tmp1="${line%@*}"  
            local tmp2="${tmp1#*:}"
            trim "$tmp2"
            cpu="$trimmed"
            (( break_counter-- ))
        elif [[ "$line" == 'siblings'* ]] ; then
            local tmp1="${line#*:}"
            trim "$tmp1"
            cpu_count="$trimmed"
            (( break_counter-- ))
        fi
    done < "$cpu_file" || return 0
}
get_cpu_dynamic() {
    local interval="${1}"
    # cpu speed
    # ---------------------------------------------
    # Tip: /sys/devices/ : 
    #           real device tree based on actual hardware hierarchy
    #           and how the kernel sees them
    #      /sys/class/ : 
    #           grouping of all devices based of type, no hierarchy,
    #           made for convinence
    local speed_dir="/sys/devices/system/cpu/cpu0/cpufreq"
    cpu_speed="$(( $( < "${speed_dir}/cpuinfo_avg_freq" ) / 1000 ))"
    cpu_speed_max="$(( $( < "${speed_dir}/cpuinfo_max_freq" ) / 1000 ))"
    cpu_speed_min="$(( $( < "${speed_dir}/cpuinfo_min_freq" ) / 1000 ))"
    # Select the right temperature file.
    # ---------------------------------
    # hwmon: The hardware monitoring subsystem
    # provides info like temp,fan speed,voltage
    for temp_dir in /sys/class/hwmon/*; do
        [[ "$(< "${temp_dir}/name")" =~ \
        (cpu_thermal|coretemp|fam15h_power|k10temp) ]] && {
            local temp_dirs=("$temp_dir"/temp*_input)
            local temp_file=${temp_dirs[0]}
            break
        }
    done
    # get temp in deg
    cpu_temp="$(( "$( < "$temp_file" )" / 1000 ))"
    # cpu usage
    # -------------------------------------
    # read only the first line, it contains the avarage
    # then calculate the diff in idle time and total time 
    # to the the diff in active time
    local usage_file="/proc/stat"
    local cpu user nice system idle iowait irq softirq steal guest guest_nice
    read -r cpu user nice system idle iowait irq softirq steal guest guest_nice \
        < "$usage_file"
    local idle1=$((idle + iowait))
    local total1=$((user + nice + system + idle + iowait + irq + softirq + steal))
    sleep "$interval"
    read -r cpu user nice system idle iowait irq softirq steal guest guest_nice \
        < "$usage_file"
    local idle2=$((idle + iowait))
    local total2=$((user + nice + system + idle + iowait + irq + softirq + steal))
    local total_delta=$((total2 - total1))
    local idle_delta=$((idle2 - idle1))
    cpu_usage=$(( 1000 * (total_delta - idle_delta) / total_delta ))
}
cpu_daemon(){
    get_cpu
    while true ; do
        get_cpu_dynamic 1
        local cpu_data="
cpu,$cpu
cpu_count,$cpu_count
cpu_usage,$cpu_usage
cpu_temp,$cpu_temp
cpu_speed,$cpu_speed
cpu_speed_min,$cpu_speed_min
cpu_speed_max,$cpu_speed_max
"
        printf '%s' "$cpu_data" > "$cpu_cache_file"    
    done
}
