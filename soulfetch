# Draw {{{
draw(){
    vec2_unpack "$CURSOR_POS"
    # scroll to have a clean full screen
    printf '\e[%iS' "$Y"
    # move up the cursor the same amount
    printf '\e[%iA' "$Y"
    # Anchor the cursor
    printf '\e[s'
    while true ; do
        # calculate frame height, used in DEINIT(), irrelevent in this func
        local lc=0
        while IFS= read -r line ; do ((lc++)) ; done < "$frame_cache_file"
        ((lc > frame_height)) && frame_height="$lc"
        printf '%i' "$frame_height" > "$frame_height_cache_file"
        # ----------------------------------

        if [[ -s "$frame_cache_file" ]] ; then
            # clean till the end of screen 
            printf '\e[0J'
            # Print frame
            while IFS= read -r line ; do
                printf "%b\n" "$line"
            done < "$frame_cache_file"
            # Move cursor to Anchor
            printf '\e[u'
        fi
        sleep 0.1
    done
}
