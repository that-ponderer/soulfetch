# Hooks {{{
clean_cache(){
    local cache
    for cache in "$cache_files"* ; do
        rm -rf "$cache" 2> /dev/null
    done
}
DEINIT(){
    # Move cursor to the end of the output
    local frame_height
    frame_height="$(< "$frame_height_cache_file")"
    printf '\e[%iB' "$frame_height"
    # Unhide cursor
    printf "\e[?25h"
    # Kill daemons
    for pid in "${daemon_PID_arr[@]}" ; do
        kill "$pid" 2> /dev/null
        wait "$pid" 2> /dev/null
    done
    # Remove caches
    clean_cache
    # restore ^C printing
    stty echoctl
}
INIT() {
    # check for other instances
    for cache in "$cache_files"* ; do
        [[ -s "$cache" ]] && \
            printf '%b' '\e[32m*\e[0m An instance is already running...\n' && \
            clean_cache ; exit 1
    done
    # Hide cursor
    printf "\e[?25l"
    # diable ^C printing
    stty -echoctl

    get_cursor_pos
}
