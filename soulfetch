# Logo {{{
get_height() {
    local lc=0
    if [[ -s "$info_cache_file" ]] ; then
        while read -r line ;  do 
            ((lc++))
        # I had to do this because the file is not formatted 
        # and contains literal newlines, the file is all in one
        # line and the first char is a '\n', this trips read up
        done < <( printf '%b' "$(< "$info_cache_file")" )
        HEIGHT="$(( lc - 2 ))"
    fi
}
plasma_effect(){
    local x="$1"
    local y="$2"
    local W="$3"
    local H="$4"
    local t="$5"

    local gradient_ascii=(
    $'\e[31m \e[0m' 
    $'\e[91m.\e[0m' 
    $'\e[32m:\e[0m' 
    $'\e[92m-\e[0m' 
    $'\e[33m=\e[0m' 
    $'\e[93m+\e[0m' 
    $'\e[34m*\e[0m' 
    $'\e[94mp\e[0m' 
    $'\e[35m#\e[0m' 
    $'\e[95m%\e[0m' 
    $'\e[36m@\e[0m' 
    $'\e[96mW\e[0m' 
    $'\e[37m8\e[0m'
    $'\e[97mB\e[0m')
    local g_len=${#gradient_ascii[@]}

    local a=$(( x + t ))
    local b=$(( y + t ))
    local c=$(( x + y + t ))
    
    local idx1=$(( (a % W) * SIN_DENSITY / W ))
    local idx2=$(( (b % H) * SIN_DENSITY / H ))
    local idx3=$(( (c % (W+H)) * SIN_DENSITY / (W+H) ))
    
    v1=${SIN_TABLE[$idx1]}
    v2=${SIN_TABLE[$idx2]}
    v3=${SIN_TABLE[$idx3]}
    
    local value=$(( v1 + v2 + v3 ))

    index=$(( (value + 3 * SIN_RANGE) * g_len / ( 6 * SIN_RANGE ) ))
    (( index < 0 )) && index=0
    (( index >= g_len )) && index=$((g_len - 1))

    CHAR="${gradient_ascii[index]}"
}
get_points(){
    local time="$1"
    for ((x=0; x < WIDTH; x++)) ; do
        for ((y=0; y < HEIGHT; y++)) ; do
            vec2_pack "$x" "$y"
            plasma_effect "$x" "$y" "$WIDTH" "$HEIGHT" "$time"
            POINTS["$VEC2"]="$CHAR"
        done
    done
}
get_logo(){
    for ((y=0; y < HEIGHT; y++)); do
        for ((x=0; x < WIDTH; x++)); do
            vec2_pack "$x" "$y"
            LOGO+="${POINTS["$VEC2"]}${POINTS["$VEC2"]}"
        done
        LOGO+=$'\n'
    done
}
draw_borders(){
    local _logo
    local horizontal='тХР'
    local vertical='тХС'
    local corner_tr='тХЧ'
    local corner_tl='тХФ'
    local corner_dr='тХЭ'
    local corner_dl='тХЪ'

    _logo+="$corner_tl\
$(for ((i=0;i < WIDTH * 2 ; i++)) ; do printf '%s' "$horizontal" ; done )\
$corner_tr\n"
    while IFS= read -r line ; do
        _logo+="$vertical$line$vertical\n"
    done <<< "${LOGO%$'\n'}"
    _logo+="$corner_dl\
$(for ((i=0;i < WIDTH * 2; i++)) ; do printf '%s' "$horizontal" ; done )\
$corner_dr\n"

    LOGO="$_logo"
    LOGO+=$'\n'
}
logo_daemon(){
    declare WIDTH="$logo_width"
    declare HEIGHT=0
    declare LOGO=""
    declare CHAR=''
    declare -A POINTS
    local time=0
    while true ; do 
        LOGO=''
        POINTS=()
        get_height
        (( "$HEIGHT" <= 0 )) && sleep 1 && continue
        get_points "$time"
        get_logo
        draw_borders
        printf '%s' "$LOGO" > "$logo_cache_file"
        ((time++)) 
        sleep 0.1
    done
}
